    "repository": {
        "type": "git",
        "url": "git+https://github.com/swetzel/confetti.js.git"
    },
    "devDependencies": {
        "jsdom": "^28.1.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
