{
    "name": "@hiseb/confetti",
    "version": "2.2.0",
    "description": "A lightweight confetti browser animation library",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "require": "./dist/index.js",
            "import": "./dist/index.mjs"
        },
        "./confetti.min.js": "./dist/confetti.min.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
